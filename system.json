{
  "id": "gothic-tales",
  "title": "Gothic Tales",
  "description": "Spielsystem für Gothic Tales mit gehärtetem Foundry-VTT-14-Manifest, bereinigten Release-Prüfungen, NSC-/Monsterbeschreibungen, Talent-Hovertexten, verbessertem Bogenlayout, Kartenpaket, Item-Hilfetexten und erweiterten Talentbäumen für Berufe, Lehren und Künste.",
  "version": "0.4.3",
  "authors": [
    {
      "name": "Kuberia"
    }
  ],
  "compatibility": {
    "minimum": "14",
    "verified": "14.368",
    "maximum": "14"
  },
  "url": "https://github.com/striker-sys/gothic-tales-vtt",
  "manifest": "https://raw.githubusercontent.com/striker-sys/gothic-tales-vtt/main/system.json",
  "download": "https://github.com/striker-sys/gothic-tales-vtt/releases/latest/download/gothic-tales.zip",
  "esmodules": [
    "scripts/gothic-tales.mjs",
    "scripts/gothic-tales-version.mjs"
  ],
  "styles": [
    "styles/gothic-tales.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "de",
      "name": "Deutsch",
      "path": "lang/de.json"
    },
    {
      "lang": "de-DE",
      "name": "Deutsch (Deutschland)",
      "path": "lang/de.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {"htmlFields": ["biography", "notes", "sourceText", "inventoryText", "strengthsWeaknesses", "lootText"]},
      "npc": {"htmlFields": ["biography", "notes", "sourceText", "inventoryText", "strengthsWeaknesses", "lootText"]},
      "monster": {"htmlFields": ["biography", "notes", "sourceText", "inventoryText", "strengthsWeaknesses", "lootText"]}
    },
    "Item": {
      "weapon": {"htmlFields": ["description", "sourceText"]},
      "shield": {"htmlFields": ["description", "sourceText"]},
      "armor": {"htmlFields": ["description", "sourceText"]},
      "spell": {"htmlFields": ["description", "sourceText"]},
      "talent": {"htmlFields": ["description", "sourceText"]},
      "trait": {"htmlFields": ["description", "sourceText"]},
      "equipment": {"htmlFields": ["description", "sourceText"]},
      "consumable": {"htmlFields": ["description", "sourceText"]}
    }
  },
  "initiative": "1d20 + @initiative.bonus",
  "primaryTokenAttribute": "hp",
  "secondaryTokenAttribute": "mana",
  "license": "LICENSE.txt",
  "grid": {"type": 1, "distance": 1, "units": "Feld"},
  "background": "systems/gothic-tales/assets/gt-background.webp",
  "thumbnail": "systems/gothic-tales/assets/gt-thumbnail.webp",
  "readme": "https://github.com/striker-sys/gothic-tales-vtt/blob/main/README.md",
  "bugs": "https://github.com/striker-sys/gothic-tales-vtt/issues",
  "type": "system"
}
