{
  "id": "gothic-tales",
  "title": "Gothic Tales",
  "description": "Spielsystem für Gothic Tales mit System-Compendien im Manifest, ohne Legacy-Welt-Importer. Enthält bereinigte Packdaten, V2-Bögen, Nachschlagewerke, Actoren, Ausrüstung, Talente und Karten direkt als Systempacks.",
  "version": "0.6.3",
  "authors": [
    {
      "name": "Kuberia"
    }
  ],
  "compatibility": {
    "minimum": "14",
    "verified": "14.368",
    "maximum": "14"
  },
