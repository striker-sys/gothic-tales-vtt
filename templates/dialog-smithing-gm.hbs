<form class="gothic-tales gt-dialog gt-smithing-gm">
  <header class="gt-profession-tools-header">
    <div>
      <div class="gt-talent-chat-kicker">Berufs-Minispiel</div>
      <h2><i class="fas fa-fire-burner"></i> Schmiedekunst vorbereiten</h2>
      <p>Schmiedeprojekt für einen Spieler starten.</p>
    </div>
  </header>

  <div class="gt-dialog-grid">
    <label>Zielspieler
      <select class="gt-smithing-user">
        <option value="">Spieler wählen</option>
        {{#each users}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>{{/each}}
      </select>
    </label>
    <label class="gt-check-row">
      <input class="gt-smithing-forge" type="checkbox" {{#if hasForge}}checked{{/if}}>
      Schmiede vorhanden
    </label>
    <label class="gt-check-row">
      <input class="gt-smithing-hammer" type="checkbox" {{#if hasHammer}}checked{{/if}}>
      Schmiedehammer bestätigt
    </label>
  </div>

  <label class="gt-full-field">Notiz
    <textarea class="gt-smithing-note" rows="3" placeholder="Optional: Schmiede, Material, Helfer">{{note}}</textarea>
  </label>

  <footer class="gt-dialog-actions">
    <button type="submit"><i class="fas fa-paper-plane"></i> An Spieler senden</button>
    <button type="button" class="gt-dialog-cancel"><i class="fas fa-xmark"></i> Schließen</button>
  </footer>
</form>
