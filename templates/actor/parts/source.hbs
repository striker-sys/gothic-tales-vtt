{{!-- Quellen-Partial: zeigt ursprüngliche Buch-/Seiten-/Bild-/Textmetadaten importierter Actoren an. --}}
<section class="gt-panel source-panel gt-parchment-panel">
  <h2>Quelle</h2>
  <div class="gt-source-meta">
    <label>Buch <input name="system.sourceBook" type="text" value="{{system.sourceBook}}"></label>
    <label>Seite <input name="system.sourcePage" type="text" value="{{system.sourcePage}}"></label>
  </div>
  <div class="gt-source-text gt-scroll">{{{system.sourceText}}}</div>
</section>
