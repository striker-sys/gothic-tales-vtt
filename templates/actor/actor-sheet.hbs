{{!-- Actor-Bogenlayout: kombiniert abgeleitete Werte, Kampfaktionen, Inventar, Talente, Erstellungswerkzeuge und Quellenangaben für Charaktere, NSCs und Monster. --}}
<form class="{{cssClass}} gt-sheet gt-v2-form actor-sheet {{#if sheetLocked}}gt-locked{{/if}}" autocomplete="off">
  <header class="gt-header gt-paper-header gt-actor-hero-header">
    <button type="button" class="gt-image-picker gt-document-image-button" title="Bild auswählen"><img class="gt-document-image" src="{{documentImage}}" alt="{{actor.name}}"></button>

    <div class="gt-title-block gt-actor-title-block">
      <label class="gt-small-label">{{actorTypeLabel}}</label>
      <input class="gt-name" name="name" type="text" value="{{actor.name}}" placeholder="Name des Helden / der Figur">
      <div class="gt-subline gt-actor-subline">
        <label>Name des Spielers <input name="system.playerName" type="text" value="{{system.playerName}}"></label>
        <label>Fraktion <input name="system.faction" type="text" value="{{system.faction}}"></label>
      </div>
      <div class="gt-header-defense-stack" aria-label="Verteidigung und Rüstungsbonus">
        <strong>Verteidigung</strong>
        <div class="gt-defense-row gt-defense-base-row">
          <span class="gt-defense-row-label">Grund</span>
          <label><span>RK</span><input name="system.defenses.rk.value" type="number" value="{{system.defenses.rk.value}}" readonly></label>
          <label><span>ELE</span><input name="system.defenses.ele.value" type="number" value="{{system.defenses.ele.value}}" readonly></label>
          <label><span>MA</span><input name="system.defenses.ma.value" type="number" value="{{system.defenses.ma.value}}" readonly></label>
        </div>
        <div class="gt-defense-row gt-defense-bonus-row">
          <span class="gt-defense-row-label">Bonus</span>
          <label class="gt-armor-bonus"><span>RK</span><input name="system.armorBonus.rk" type="number" value="{{system.armorBonus.rk}}"></label>
          <label class="gt-armor-bonus"><span>ELE</span><input name="system.armorBonus.ele" type="number" value="{{system.armorBonus.ele}}"></label>
          <label class="gt-armor-bonus"><span>MA</span><input name="system.armorBonus.ma" type="number" value="{{system.armorBonus.ma}}"></label>
        </div>
      </div>
    </div>

    <div class="gt-top-values">
      <div class="gt-level-strip">
        <label>Stufe <input name="system.stufe" type="number" value="{{system.stufe}}"></label>
        {{#if isCharacter}}
          <label>LP <span><input name="system.lp.value" type="number" value="{{system.lp.value}}"> / <input name="system.lp.max" type="number" value="{{system.lp.max}}"></span></label>
          <button type="button" class="gt-level-manage"><i class="fas fa-arrow-up-arrow-down"></i> Stufe ändern</button>
        {{/if}}
      </div>
      <div class="gt-vitals-grid">
        <label class="gt-vital-pair"><span>TP</span><b><input name="system.hp.value" type="number" value="{{system.hp.value}}"> / <input name="system.hp.max" type="number" value="{{system.hp.max}}"></b></label>
        <label class="gt-vital-pair"><span>Mana</span><b><input name="system.mana.value" type="number" value="{{system.mana.value}}"> / <input name="system.mana.max" type="number" value="{{system.mana.max}}"></b></label>
        <label><span>Initiative</span><input name="system.initiative.value" type="number" value="{{system.initiative.value}}"></label>
        <label><span>Bewegung</span><input name="system.movement.value" type="number" value="{{system.movement.value}}"></label>
        <label class="gt-vital-pair gt-tracker-mini"><span>Erschöpfung</span><b><input name="system.exhaustion.value" type="number" value="{{system.exhaustion.value}}"> / <input name="system.exhaustion.max" type="number" value="{{system.exhaustion.max}}"></b></label>
        <label class="gt-vital-pair gt-tracker-mini"><span>Todeskampf</span><b><input name="system.deathCounter.value" type="number" value="{{system.deathCounter.value}}"> / <input name="system.deathCounter.max" type="number" value="{{system.deathCounter.max}}"></b></label>
      </div>
    </div>

    <div class="gt-header-actions">
      <button type="button" class="gt-recalculate"><i class="fas fa-calculator"></i> Werte</button>
      <button type="button" class="gt-rest-button"><i class="fas fa-bed"></i> Ausruhen</button>
      <button type="button" class="gt-combat-end-button"><i class="fas fa-flag-checkered"></i> Kampf vorbei</button>
      <button type="button" class="gt-lock-toggle"><i class="fas {{#if sheetLocked}}fa-lock{{else}}fa-unlock{{/if}}"></i> {{#if sheetLocked}}Gesperrt{{else}}Bearbeiten{{/if}}</button>
    </div>
  </header>

  <div class="gt-sheet-layout">
    <section class="sheet-body">
      <div class="tab main" data-group="primary" data-tab="main">
        <div class="gt-grid-main gt-main-sheet-grid gt-main-sheet-grid-vitals-top">
          <section class="gt-panel attributes-panel gt-parchment-panel">
            <h2>Attribute</h2>
            {{> "systems/gothic-tales/templates/actor/parts/attributes.hbs" list=attributeList path="attributes" kind="attr"}}
          </section>


          <section class="gt-panel skills-panel gt-parchment-panel">
            <h2>Fähigkeiten</h2>
            {{> "systems/gothic-tales/templates/actor/parts/attributes.hbs" list=skillList path="skills" kind="skill"}}
          </section>
        </div>
      </div>

      <div class="tab combat" data-group="primary" data-tab="combat">
        <div class="gt-grid-main combat-grid">
          <section class="gt-panel gt-parchment-panel">
            <h2>Waffen, Schilde & Zauber</h2>
            <p class="gt-help">Angriff: W20 + Attributswürfel & Bonus. Schaden: Waffen-/Zauberwürfel und je nach Regel Attributswurf.</p>
            {{> "systems/gothic-tales/templates/actor/parts/items.hbs" groups=combatGroups compact=true}}
          </section>
          <section class="gt-panel gt-parchment-panel">
            <h2>Schnellwürfe</h2>
            <div class="gt-action-grid">
              {{#each attributeList}}
                <button type="button" class="gt-roll gt-quick-roll" data-label="{{label}}" data-formula="{{formula}}"><span>{{label}}</span><small>{{formula}}</small></button>
              {{/each}}
            </div>
            <h3>Vorteil & Nachteil</h3>
            <div class="gt-action-grid">
              <button type="button" class="gt-roll" data-label="kleiner Vorteil/Nachteil" data-formula="w2">w2</button>
              <button type="button" class="gt-roll" data-label="mittlerer Vorteil/Nachteil" data-formula="w6">w6</button>
              <button type="button" class="gt-roll" data-label="großer Vorteil/Nachteil" data-formula="w12">w12</button>
              <button type="button" class="gt-roll" data-label="Initiative" data-formula="{{initiativeFormula}}">Initiative <small>{{initiativeFormula}}</small></button>
            </div>
          </section>
        </div>
      </div>

      <div class="tab inventory" data-group="primary" data-tab="inventory">
        <div class="gt-grid-main inventory-grid">
          {{> "systems/gothic-tales/templates/actor/parts/items.hbs" groups=itemGroups}}
          <section class="gt-panel gt-parchment-panel">
            <h2>Inventartext</h2>
            <div class="gt-description-preview gt-scroll">{{{system.inventoryText}}}</div><button type="button" class="gt-description-edit" data-path="inventoryText" data-label="Inventartext"><i class="fas fa-edit"></i> Inventartext bearbeiten</button>
          </section>
        </div>
      </div>

      <div class="tab equipment" data-group="primary" data-tab="equipment">
        <div class="gt-grid-main inventory-grid">
          <section class="gt-panel gt-parchment-panel">
            <h2>Waffen</h2>
            {{> "systems/gothic-tales/templates/actor/parts/items.hbs" groups=(lookup itemGroups "weapons") single=true}}
          </section>
          <section class="gt-panel gt-parchment-panel">
            <h2>Schilde</h2>
            {{> "systems/gothic-tales/templates/actor/parts/items.hbs" groups=(lookup itemGroups "shields") single=true}}
            <h2>Rüstungen</h2>
            {{> "systems/gothic-tales/templates/actor/parts/items.hbs" groups=(lookup itemGroups "armor") single=true}}
          </section>
        </div>
      </div>

      <div class="tab spells" data-group="primary" data-tab="spells">
        <section class="gt-panel gt-parchment-panel">
          <h2>Zauber</h2>
          <p class="gt-help">Dieser Bereich ist vorbereitet. Die Zauberlogik wird später getrennt ausgebaut.</p>
          {{> "systems/gothic-tales/templates/actor/parts/items.hbs" groups=(lookup itemGroups "spells") single=true}}
        </section>
      </div>

      <div class="tab magic" data-group="primary" data-tab="magic">
        <section class="gt-panel gt-parchment-panel gt-magic-circle-panel">
          <header class="gt-magic-circle-header">
            <div>
              <h2><i class="fas fa-wand-sparkles"></i> Magiekreise</h2>
              <p>Uraltes Wissen, gebundene Macht und vorbereitete Würfel für Zauberhandlungen.</p>
            </div>
            <div class="gt-magic-current">
              <span>Aktueller Kreis</span>
              <strong>{{currentMagicCircleLabel}}</strong>
              <small>{{currentMagicCircleDiceText}}</small>
            </div>
          </header>

          <div class="gt-magic-dice-grid">
            {{#each magicCircleSlots}}
            <button type="button" class="gt-magic-die-slot {{#if filled}}filled{{/if}} {{#if used}}used{{/if}} {{#unless active}}inactive{{/unless}}" data-slot-index="{{index}}" {{#unless active}}disabled{{/unless}}>
              {{#if used}}<span class="gt-magic-die-used-mark">Benutzt</span>{{/if}}
              <strong>{{#if filled}}{{result}}{{else}}—{{/if}}</strong>
              <small>{{#if die}}{{label}}{{else}}kein Würfel{{/if}}</small>
            </button>
            {{/each}}
          </div>

          <div class="gt-magic-actions">
            <button type="button" class="gt-magic-roll-all"><i class="fas fa-dice"></i> Alle Magiewürfel werfen</button>
            <button type="button" class="gt-open-magic-tree"><i class="fas fa-circle-nodes"></i> Magiekreise öffnen</button>
          </div>
        </section>

        <section class="gt-panel gt-parchment-panel gt-magic-skills-panel">
          <h2>Gelerntes Wissen</h2>
          {{#if hasMagicCircleCategories}}
          <div class="gt-talent-category-list gt-magic-skill-list">
            {{#each magicCircleCategories}}
            <section class="gt-talent-category gt-magic-skill-category">
              <header class="gt-talent-category-header">
                <h3>{{label}}</h3>
                <span>{{count}} gelernt</span>
              </header>
              <div class="gt-talent-card-list">
                {{#each cards}}
                <article class="gt-actor-talent-card gt-magic-skill-card" data-talent-key="{{key}}">
                  <div class="gt-talent-card-main">
                    <div class="gt-talent-card-text">
                      <h3>{{name}}</h3>
                      <small>{{treeLabel}}</small>
                      {{#if attributeText}}<small class="gt-talent-consumes">{{attributeText}}</small>{{/if}}
                    </div>
                    <div class="gt-talent-card-side">
                      <span class="gt-talent-uses unlimited"><i class="fas fa-moon"></i> Kreis</span>
                      <div class="gt-talent-card-actions">
                        <button type="button" class="gt-talent-info" data-gt-tooltip="{{tooltip}}"><i class="fas fa-circle-info"></i> Lesen</button>
                        <button type="button" class="gt-use-magic-skill" data-tree-id="{{treeId}}" data-node-id="{{nodeId}}"><i class="fas fa-wand-sparkles"></i> Ausführen</button>
                      </div>
                    </div>
                  </div>
                </article>
                {{/each}}
              </div>
            </section>
            {{/each}}
          </div>
          {{else}}
          <p class="gt-help">Noch kein Magiekreis gelernt. Öffne den Magiekreis-Baum und lerne den ersten Kreis.</p>
          {{/if}}
        </section>
      </div>

      <div class="tab druid" data-group="primary" data-tab="druid">
        <section class="gt-panel gt-parchment-panel gt-druid-panel">
          <h2><i class="fas fa-leaf"></i> Druidenkunst</h2>
          <p class="gt-help">Dieser Bereich ist vom normalen Talentbaum getrennt und für die nächste Ausbaustufe vorbereitet.</p>
          <p>Die Daten liegen nun in einer eigenen Datei und können später mit einem eigenen Baum und eigenen Funktionen versehen werden.</p>
        </section>
      </div>

      <div class="tab talents" data-group="primary" data-tab="talents">
        <section class="gt-panel gt-parchment-panel gt-talent-control-panel">
          <h2>Talente & Anwendungen</h2>
          {{#if isCharacter}}<p>Öffnet den anklickbaren Talentbaum. Lernpunkte werden bei Auswahl direkt verrechnet. Talente mit Anwendungen füllen sich nach einem Kampf über den Button „Kampf vorbei“ wieder auf.</p>{{else}}<p>Öffnet den Talentbaum. NSCs und Monster können Talente ohne Lernpunkte erhalten; Mindestattribute werden ignoriert.</p>{{/if}}
          <button type="button" class="gt-open-talent-tree"><i class="fas fa-sitemap"></i> Talentbaum öffnen</button>

          {{#if hasTalentCategories}}
          <div class="gt-talent-category-list">
            {{#each talentCategories}}
            <section class="gt-talent-category">
              <header class="gt-talent-category-header">
                <h3>{{label}}</h3>
                <span>{{count}} gelernt</span>
              </header>
              <div class="gt-talent-card-list">
                {{#each cards}}
                <article class="gt-actor-talent-card {{#unless canExecute}}depleted{{/unless}}" data-talent-key="{{key}}">
                  <div class="gt-talent-card-main">
                    <div class="gt-talent-card-text">
                      <h3>{{name}}</h3>
                      <small>{{treeLabel}}</small>
                      {{#if consumeText}}<small class="gt-talent-consumes">{{consumeText}}</small>{{/if}}
                    </div>
                    <div class="gt-talent-card-side">
                      <span class="gt-talent-uses {{#unless usesLimited}}unlimited{{/unless}}" data-pool="{{poolKey}}" title="{{poolLabel}}">
                        {{#if usesLimited}}{{usesCurrent}} / {{usesMax}}{{else}}frei{{/if}}
                      </span>
                      <div class="gt-talent-card-actions">
                        <button type="button" class="gt-talent-info" data-gt-tooltip="{{tooltip}}"><i class="fas fa-circle-info"></i> Lesen</button>
                        <button type="button" class="gt-use-talent" data-source="{{source}}" data-tree-id="{{treeId}}" data-node-id="{{nodeId}}" data-item-id="{{itemId}}" {{#unless canExecute}}disabled{{/unless}}><i class="fas fa-bolt"></i> {{executeLabel}}</button>
                      </div>
                    </div>
                  </div>
                </article>
                {{/each}}
              </div>
            </section>
            {{/each}}
          </div>
          {{else}}
          <p class="gt-help">Noch keine Talente gelernt oder als Talent-Item angelegt.</p>
          {{/if}}
        </section>
        {{> "systems/gothic-tales/templates/actor/parts/items.hbs" groups=(lookup itemGroups "talents") single=true}}
      </div>

      <div class="tab creation" data-group="primary" data-tab="creation">
        <section class="gt-panel gt-parchment-panel">
          <h2>Editor & Generator</h2>
          <p>Der Charakter-Editor führt durch Level, Lernpunkte, Attribute, Fähigkeiten, Stärken/Schwächen, Talente und Startausrüstung. Der NSC-Generator erzeugt NSCs mit fester Initiative, Inventar und Aktionszahl.</p>
          <button type="button" class="gt-open-creator"><i class="fas fa-user-plus"></i> Charakter-Editor öffnen</button>
          <button type="button" class="gt-open-npc-creator"><i class="fas fa-users"></i> NSC-Generator öffnen</button>
        </section>
        <section class="gt-panel gt-parchment-panel">
          <h2>Stärken & Schwächen</h2>
          <div class="gt-description-preview gt-scroll">{{{system.strengthsWeaknesses}}}</div><button type="button" class="gt-description-edit" data-path="strengthsWeaknesses" data-label="Stärken & Schwächen"><i class="fas fa-edit"></i> Stärken & Schwächen bearbeiten</button>
        </section>
      </div>

      <div class="tab notes" data-group="primary" data-tab="notes">
        <div class="gt-grid-main notes-grid">
          <section class="gt-panel gt-parchment-panel"><h2>Hintergrund</h2><div class="gt-description-preview gt-scroll">{{{system.biography}}}</div><button type="button" class="gt-description-edit" data-path="biography" data-label="Hintergrund"><i class="fas fa-edit"></i> Hintergrund bearbeiten</button></section>
          <section class="gt-panel gt-parchment-panel"><h2>Notizen</h2><div class="gt-description-preview gt-scroll">{{{system.notes}}}</div><button type="button" class="gt-description-edit" data-path="notes" data-label="Notizen"><i class="fas fa-edit"></i> Notizen bearbeiten</button></section>
        </div>
      </div>

      <div class="tab source" data-group="primary" data-tab="source">
        {{> "systems/gothic-tales/templates/actor/parts/source.hbs"}}
      </div>
    </section>

    <nav class="sheet-tabs tabs gt-side-tabs" data-group="primary">
      <a class="item" data-tab="main"><i class="fas fa-id-card"></i><span>Bogen</span></a>
      <a class="item" data-tab="combat"><i class="fas fa-dice-d20"></i><span>Kampf</span></a>
      <a class="item" data-tab="inventory"><i class="fas fa-sack"></i><span>Inventar</span></a>
      <a class="item" data-tab="equipment"><i class="fas fa-shield-halved"></i><span>Ausrüstung</span></a>
      <a class="item" data-tab="spells"><i class="fas fa-scroll"></i><span>Zauber</span></a>
      <a class="item" data-tab="magic"><i class="fas fa-wand-sparkles"></i><span>Magiekreise</span></a>
      <a class="item" data-tab="druid"><i class="fas fa-leaf"></i><span>Druidenkunst</span></a>
      <a class="item" data-tab="talents"><i class="fas fa-sitemap"></i><span>Talente</span></a>
      <a class="item" data-tab="creation"><i class="fas fa-pen-to-square"></i><span>Editor</span></a>
      <a class="item" data-tab="notes"><i class="fas fa-feather"></i><span>Notizen</span></a>
      <a class="item" data-tab="source"><i class="fas fa-book"></i><span>Quelle</span></a>
    </nav>
  </div>
</form>
